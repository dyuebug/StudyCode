/*
【核心概念】构造函数（Constructor）

是什么？
- 构造函数是类的特殊成员函数，用于初始化对象
- 对象创建时自动调用，无需手动调用

为什么需要？
- 自动初始化对象，避免使用未初始化的数据
- 简化对象创建过程
- 保证对象创建时处于有效状态

核心特点：
- 函数名与类名相同
- 没有返回类型（连void都不写）
- 可以重载（多个构造函数）
- 对象创建时自动调用
*/

// ============================================
// 第一部分：核心概念详解 ⭐⭐⭐⭐⭐
// ============================================

#include <iostream>
#include <string>
using namespace std;

int main() {
    cout << string(60, '=') << endl;
    cout << "第一部分：核心概念详解 ⭐⭐⭐⭐⭐" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 1.1 概念1：什么是构造函数
    // --------------------------------------------

    cout << "\n1.1 什么是构造函数？" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【构造函数（Constructor）】

是什么？
- 构造函数是类的特殊成员函数
- 用于在对象创建时初始化对象

特点：
1. 函数名与类名完全相同
2. 没有返回类型（连void都不写）
3. 对象创建时自动调用
4. 可以有参数
5. 可以重载（定义多个构造函数）

语法：
class ClassName {
public:
    ClassName() {  // 构造函数
        // 初始化代码
    }
};

调用时机：
- 创建对象时自动调用
- 例如：ClassName obj;  // 自动调用构造函数
)" << endl;

    // --------------------------------------------
    // 1.2 概念2：默认构造函数
    // --------------------------------------------

    cout << "\n1.2 默认构造函数" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【默认构造函数】

是什么？
- 无参数的构造函数
- 如果没有定义任何构造函数，编译器会自动生成一个默认构造函数

特点：
- 无参数或所有参数都有默认值
- 用于创建对象时不提供参数

语法：
class ClassName {
public:
    ClassName() {  // 默认构造函数
        // 初始化代码
    }
};

调用：
ClassName obj;  // 调用默认构造函数

注意：
- 如果定义了带参数的构造函数，编译器不会自动生成默认构造函数
- 此时如果需要默认构造函数，必须手动定义
)" << endl;

    // --------------------------------------------
    // 1.3 概念3：带参数的构造函数
    // --------------------------------------------

    cout << "\n1.3 带参数的构造函数" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【带参数的构造函数】

是什么？
- 有参数的构造函数
- 用于在创建对象时传入初始值

特点：
- 可以有一个或多个参数
- 创建对象时必须提供参数

语法：
class ClassName {
public:
    ClassName(int x, string s) {  // 带参数的构造函数
        // 使用参数初始化成员变量
    }
};

调用：
ClassName obj(10, "hello");  // 传入参数
)" << endl;

    // --------------------------------------------
    // 1.4 重要概念：初始化列表 ⭐⭐⭐⭐⭐
    // --------------------------------------------

    cout << "\n1.4 初始化列表" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【初始化列表（Initializer List）】

是什么？
- 构造函数的特殊语法，用于初始化成员变量
- 在构造函数体执行前初始化成员变量

为什么需要？
- 效率更高（直接初始化，而不是先默认初始化再赋值）
- 某些情况下必须使用（const成员、引用成员）

语法：
class ClassName {
private:
    int x;
    string s;
public:
    ClassName(int a, string b) : x(a), s(b) {
        // 构造函数体
    }
};

对比：
// 方式1：在构造函数体内赋值
ClassName(int a) {
    x = a;  // 先默认初始化x，再赋值
}

// 方式2：使用初始化列表（推荐）
ClassName(int a) : x(a) {
    // x直接初始化为a
}

优势：
- 效率更高
- 可以初始化const成员和引用成员
- 代码更简洁
)" << endl;

    return 0;
}

// ============================================
// 第二部分：基础操作实践
// ============================================

#include <iostream>
#include <string>
using namespace std;

// --------------------------------------------
// 2.1 示例1：默认构造函数
// --------------------------------------------

// 定义一个点类
class Point {
private:
    int x;
    int y;

public:
    // 默认构造函数：无参数
    // 功能：将点初始化为原点(0, 0)
    Point() {
        x = 0;
        y = 0;
        cout << "调用默认构造函数：Point() - 创建点(" << x << ", " << y << ")" << endl;
    }

    // 显示点的坐标
    void display() {
        cout << "点的坐标：(" << x << ", " << y << ")" << endl;
    }
};

// --------------------------------------------
// 2.2 示例2：带参数的构造函数
// --------------------------------------------

// 定义一个矩形类
class Rectangle {
private:
    double width;
    double height;

public:
    // 带参数的构造函数
    // 参数：w - 宽度，h - 高度
    Rectangle(double w, double h) {
        width = w;
        height = h;
        cout << "调用带参数构造函数：Rectangle(" << w << ", " << h << ")" << endl;
    }

    // 计算面积
    double getArea() {
        return width * height;
    }

    // 显示信息
    void display() {
        cout << "矩形：宽=" << width << ", 高=" << height << ", 面积=" << getArea() << endl;
    }
};

// --------------------------------------------
// 2.3 示例3：构造函数重载
// --------------------------------------------

// 定义一个学生类，演示构造函数重载
class Student {
private:
    string name;
    int age;
    double score;

public:
    // 构造函数1：默认构造函数
    Student() {
        name = "未命名";
        age = 0;
        score = 0.0;
        cout << "调用构造函数1：Student()" << endl;
    }

    // 构造函数2：只初始化姓名
    Student(string n) {
        name = n;
        age = 0;
        score = 0.0;
        cout << "调用构造函数2：Student(string)" << endl;
    }

    // 构造函数3：初始化姓名和年龄
    Student(string n, int a) {
        name = n;
        age = a;
        score = 0.0;
        cout << "调用构造函数3：Student(string, int)" << endl;
    }

    // 构造函数4：初始化所有成员
    Student(string n, int a, double s) {
        name = n;
        age = a;
        score = s;
        cout << "调用构造函数4：Student(string, int, double)" << endl;
    }

    // 显示学生信息
    void display() {
        cout << "学生：" << name << ", 年龄：" << age << ", 成绩：" << score << endl;
    }
};

// --------------------------------------------
// 2.4 示例4：使用初始化列表
// --------------------------------------------

// 定义一个圆类，演示初始化列表
class Circle {
private:
    double radius;
    const double PI;  // const成员变量

public:
    // 使用初始化列表初始化成员变量
    // 语法：构造函数名(参数) : 成员1(值1), 成员2(值2) { }
    Circle(double r) : radius(r), PI(3.14159) {
        cout << "调用构造函数：Circle(" << r << ") - 使用初始化列表" << endl;
    }

    // 计算面积
    double getArea() {
        return PI * radius * radius;
    }

    // 显示信息
    void display() {
        cout << "圆：半径=" << radius << ", 面积=" << getArea() << endl;
    }
};

int main() {
    cout << string(60, '=') << endl;
    cout << "第二部分：基础操作实践" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 2.1 使用默认构造函数
    // --------------------------------------------

    cout << "\n2.1 使用默认构造函数" << endl;
    cout << string(60, '-') << endl;

    // 创建对象：自动调用默认构造函数
    Point p1;
    p1.display();

    // --------------------------------------------
    // 2.2 使用带参数的构造函数
    // --------------------------------------------

    cout << "\n2.2 使用带参数的构造函数" << endl;
    cout << string(60, '-') << endl;

    // 创建对象时传入参数
    Rectangle rect(10.0, 5.0);
    rect.display();

    // --------------------------------------------
    // 2.3 构造函数重载
    // --------------------------------------------

    cout << "\n2.3 构造函数重载" << endl;
    cout << string(60, '-') << endl;

    // 根据参数数量和类型，调用不同的构造函数
    Student stu1;  // 调用构造函数1
    stu1.display();

    Student stu2("张三");  // 调用构造函数2
    stu2.display();

    Student stu3("李四", 18);  // 调用构造函数3
    stu3.display();

    Student stu4("王五", 19, 85.5);  // 调用构造函数4
    stu4.display();

    // --------------------------------------------
    // 2.4 使用初始化列表
    // --------------------------------------------

    cout << "\n2.4 使用初始化列表" << endl;
    cout << string(60, '-') << endl;

    Circle c1(5.0);
    c1.display();

    return 0;
}

/*
==============================================
🔍 深入理解：构造函数的执行过程（选学）
==============================================

如果你想知道"为什么"，可以阅读这部分。
如果觉得难，可以跳过，不影响后续学习。

【构造函数的执行顺序】

1. 分配内存
   - 为对象分配内存空间

2. 初始化成员变量
   - 如果使用初始化列表，按照初始化列表的顺序初始化
   - 如果没有初始化列表，成员变量先默认初始化

3. 执行构造函数体
   - 执行构造函数内的代码

示例：
class MyClass {
private:
    int x;
    int y;
public:
    MyClass(int a, int b) : x(a), y(b) {
        cout << "构造函数体执行" << endl;
    }
};

执行过程：
1. 分配内存给MyClass对象
2. 使用初始化列表：x = a, y = b
3. 执行构造函数体：输出"构造函数体执行"

【初始化列表 vs 构造函数体赋值】

初始化列表：
- 直接初始化成员变量
- 效率更高
- 可以初始化const成员和引用成员

构造函数体赋值：
- 先默认初始化，再赋值
- 效率较低
- 不能初始化const成员和引用成员

推荐：优先使用初始化列表

==============================================
*/

// ============================================
// 第三部分：常见错误和陷阱 ⭐⭐⭐⭐⭐
// ============================================

#include <iostream>
#include <string>
using namespace std;

int main() {
    cout << string(60, '=') << endl;
    cout << "常见错误和陷阱 ⭐⭐⭐⭐⭐" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 3.1 错误1：构造函数写了返回类型
    // --------------------------------------------

    cout << "\n3.1 错误1：构造函数写了返回类型" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class Student {
public:
    void Student() {  // 错误：构造函数不能有返回类型
        // ...
    }
};

结果：编译错误或被当作普通成员函数

原因：构造函数不能有返回类型，连void都不能写

✅ 正确代码：
class Student {
public:
    Student() {  // 正确：没有返回类型
        // ...
    }
};

记忆技巧：
- 构造函数名 = 类名
- 没有返回类型
)" << endl;

    // --------------------------------------------
    // 3.2 错误2：定义了带参数构造函数后，忘记定义默认构造函数
    // --------------------------------------------

    cout << "\n3.2 错误2：忘记定义默认构造函数" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class Student {
public:
    Student(string n) {  // 只定义了带参数的构造函数
        name = n;
    }
private:
    string name;
};

Student stu;  // 错误：没有默认构造函数

结果：编译错误

原因：定义了带参数的构造函数后，编译器不会自动生成默认构造函数

✅ 正确代码：
class Student {
public:
    Student() {  // 手动定义默认构造函数
        name = "未命名";
    }
    Student(string n) {
        name = n;
    }
private:
    string name;
};

Student stu1;  // 正确：调用默认构造函数
Student stu2("张三");  // 正确：调用带参数的构造函数

记忆技巧：
- 定义了任何构造函数，编译器就不会自动生成默认构造函数
- 如果需要默认构造函数，必须手动定义
)" << endl;

    // --------------------------------------------
    // 3.3 错误3：对象声明时加了括号
    // --------------------------------------------

    cout << "\n3.3 错误3：对象声明时加了括号" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class Student {
public:
    Student() { }
};

Student stu();  // 错误：这是函数声明，不是对象创建

结果：stu被当作函数声明，不是对象

原因：C++的语法歧义，Student stu()被解析为函数声明

✅ 正确代码：
Student stu;  // 正确：创建对象，调用默认构造函数

记忆技巧：
- 调用默认构造函数时，不要加括号
- Student stu;  // 正确
- Student stu();  // 错误（函数声明）
)" << endl;

    // --------------------------------------------
    // 3.4 错误4：初始化列表顺序错误
    // --------------------------------------------

    cout << "\n3.4 错误4：初始化列表顺序错误" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class MyClass {
private:
    int x;
    int y;
public:
    MyClass(int a) : y(a), x(y) {  // 错误：x依赖y，但x先初始化
        // x的值是未定义的
    }
};

结果：x的值是未定义的

原因：初始化顺序由成员变量声明顺序决定，不是初始化列表顺序

✅ 正确代码：
class MyClass {
private:
    int x;
    int y;
public:
    MyClass(int a) : x(a), y(a) {  // 正确：不依赖其他成员
        // 或者
    }
    MyClass(int a) : x(a), y(x) {  // 正确：y依赖x，x先声明
        // y可以使用x的值
    }
};

记忆技巧：
- 初始化顺序 = 成员变量声明顺序
- 初始化列表的顺序不影响实际初始化顺序
- 避免成员之间的依赖
)" << endl;

    // --------------------------------------------
    // 3.5 错误5：const成员未在初始化列表中初始化
    // --------------------------------------------

    cout << "\n3.5 错误5：const成员未在初始化列表中初始化" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class MyClass {
private:
    const int x;
public:
    MyClass(int a) {
        x = a;  // 错误：const成员不能赋值
    }
};

结果：编译错误

原因：const成员必须在初始化列表中初始化，不能赋值

✅ 正确代码：
class MyClass {
private:
    const int x;
public:
    MyClass(int a) : x(a) {  // 正确：在初始化列表中初始化
        // ...
    }
};

记忆技巧：
- const成员必须在初始化列表中初始化
- 引用成员也必须在初始化列表中初始化
)" << endl;

    // --------------------------------------------
    // 3.6 错误6：忘记初始化指针成员
    // --------------------------------------------

    cout << "\n3.6 错误6：忘记初始化指针成员" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class MyClass {
private:
    int* ptr;
public:
    MyClass() {
        // 忘记初始化ptr
    }
    void setValue(int v) {
        *ptr = v;  // 错误：ptr是野指针
    }
};

结果：程序崩溃或未定义行为

原因：指针未初始化，是野指针

✅ 正确代码：
class MyClass {
private:
    int* ptr;
public:
    MyClass() {
        ptr = nullptr;  // 初始化为nullptr
        // 或者
        ptr = new int;  // 分配内存
    }
};

记忆技巧：
- 指针成员必须初始化
- 初始化为nullptr或分配内存
- 使用前检查指针是否为nullptr
)" << endl;

    // --------------------------------------------
    // 3.7 错误7：构造函数中抛出异常
    // --------------------------------------------

    cout << "\n3.7 错误7：构造函数中抛出异常" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 危险代码：
class MyClass {
public:
    MyClass() {
        int* ptr = new int[1000000000];  // 可能分配失败
        // 如果失败，对象处于不完整状态
    }
};

问题：构造函数中的异常可能导致对象处于不完整状态

✅ 正确做法：
class MyClass {
private:
    int* ptr;
public:
    MyClass() : ptr(nullptr) {
        try {
            ptr = new int[1000000000];
        } catch (...) {
            // 处理异常
            ptr = nullptr;
        }
    }
    bool isValid() {
        return ptr != nullptr;
    }
};

记忆技巧：
- 构造函数中要处理可能的异常
- 提供方法检查对象是否有效
- 或者使用异常安全的设计
)" << endl;

    return 0;
}

// ============================================
// 第四部分：函数卡片速查
// ============================================

#include <iostream>
using namespace std;

int main() {
    cout << "构造函数速查" << endl;

    cout << R"(
【构造函数类型】

1. 默认构造函数
   语法：ClassName() { }
   调用：ClassName obj;
   作用：无参数初始化对象

2. 带参数的构造函数
   语法：ClassName(int x, string s) { }
   调用：ClassName obj(10, "hello");
   作用：使用参数初始化对象

3. 使用初始化列表的构造函数
   语法：ClassName(int x) : member(x) { }
   调用：ClassName obj(10);
   作用：高效初始化成员变量

────────────────────────────────────

【构造函数规则】

1. 函数名 = 类名
2. 没有返回类型
3. 对象创建时自动调用
4. 可以重载
5. 如果没有定义，编译器自动生成默认构造函数
6. 如果定义了任何构造函数，编译器不会自动生成默认构造函数

────────────────────────────────────

【初始化列表】

语法：ClassName(int a, int b) : x(a), y(b) { }

优势：
- 效率更高
- 可以初始化const成员
- 可以初始化引用成员

注意：
- 初始化顺序由成员变量声明顺序决定
- 不是初始化列表的顺序
)" << endl;

    return 0;
}

// ============================================
// 第五部分：练习题
// ============================================

#include <iostream>
using namespace std;

int main() {
    cout << "练习题" << endl;

    cout << R"(
1. 定义一个日期类Date
   要求：
   - 有三个私有成员：year、month、day
   - 定义默认构造函数，初始化为2024-01-01
   - 定义带参数的构造函数，接受年月日参数
   - 使用初始化列表初始化成员变量
   - 提供display()方法显示日期
   提示：注意日期的有效性验证

2. 定义一个银行账户类BankAccount
   要求：
   - 有私有成员：accountNumber、balance
   - 定义默认构造函数，余额初始化为0
   - 定义带参数的构造函数，接受账号和初始余额
   - 初始余额必须 >= 0
   - 提供display()方法显示账户信息
   提示：在构造函数中验证初始余额

3. 定义一个矩形类Rectangle
   要求：
   - 有私有成员：width、height
   - 定义多个构造函数（重载）：
     * 默认构造函数：宽高都为1
     * 一个参数：正方形（宽高相等）
     * 两个参数：矩形（指定宽高）
   - 使用初始化列表
   - 提供getArea()和display()方法
   提示：构造函数重载

4. 定义一个学生类Student
   要求：
   - 有私有成员：name、age、const int id
   - 定义构造函数，初始化所有成员
   - id是const成员，必须在初始化列表中初始化
   - 提供display()方法
   提示：const成员必须用初始化列表

5. 定义一个动态数组类DynamicArray
   要求：
   - 有私有成员：int* data、int size
   - 定义构造函数，接受数组大小参数
   - 在构造函数中分配内存
   - 提供方法设置和获取元素
   提示：使用new分配内存，注意内存泄漏（下节课会学析构函数）
)" << endl;

    return 0;
}
