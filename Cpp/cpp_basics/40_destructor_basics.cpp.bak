/*
【核心概念】析构函数（Destructor）

是什么？
- 析构函数是类的特殊成员函数，用于清理对象占用的资源
- 对象销毁时自动调用，无需手动调用

为什么需要？
- 释放动态分配的内存，防止内存泄漏
- 关闭打开的文件
- 释放其他资源（网络连接、数据库连接等）

核心特点：
- 函数名是类名前加~符号
- 没有返回类型（连void都不写）
- 没有参数，不能重载
- 对象销毁时自动调用
*/

// ============================================
// 第一部分：核心概念详解 ⭐⭐⭐⭐⭐
// ============================================

#include <iostream>
#include <string>
using namespace std;

int main() {
    cout << string(60, '=') << endl;
    cout << "第一部分：核心概念详解 ⭐⭐⭐⭐⭐" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 1.1 概念1：什么是析构函数
    // --------------------------------------------

    cout << "\n1.1 什么是析构函数？" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【析构函数（Destructor）】

是什么？
- 析构函数是类的特殊成员函数
- 用于在对象销毁时清理资源

特点：
1. 函数名是类名前加~符号（例如：~ClassName）
2. 没有返回类型（连void都不写）
3. 没有参数，不能重载（一个类只能有一个析构函数）
4. 对象销毁时自动调用
5. 如果没有定义，编译器会自动生成一个默认析构函数

语法：
class ClassName {
public:
    ~ClassName() {  // 析构函数
        // 清理资源的代码
    }
};

调用时机：
- 对象生命周期结束时自动调用
- 局部对象：函数结束时
- 动态对象：delete时
- 全局对象：程序结束时
)" << endl;

    // --------------------------------------------
    // 1.2 概念2：对象的生命周期
    // --------------------------------------------

    cout << "\n1.2 对象的生命周期" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【对象的生命周期】

完整流程：
1. 创建对象 → 调用构造函数
2. 使用对象 → 调用成员函数
3. 销毁对象 → 调用析构函数

不同类型对象的生命周期：

1. 局部对象（栈对象）
   - 创建：进入作用域时
   - 销毁：离开作用域时
   - 例如：函数内定义的对象

2. 动态对象（堆对象）
   - 创建：new时
   - 销毁：delete时
   - 必须手动delete，否则内存泄漏

3. 全局对象
   - 创建：程序开始时
   - 销毁：程序结束时

4. 静态对象
   - 创建：第一次使用时
   - 销毁：程序结束时
)" << endl;

    // --------------------------------------------
    // 1.3 概念3：资源管理
    // --------------------------------------------

    cout << "\n1.3 资源管理" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
【资源管理（RAII）】

RAII = Resource Acquisition Is Initialization
资源获取即初始化

核心思想：
- 构造函数中获取资源
- 析构函数中释放资源
- 利用对象生命周期自动管理资源

常见资源：
1. 内存：new/delete
2. 文件：打开/关闭
3. 网络连接：建立/断开
4. 数据库连接：打开/关闭
5. 互斥锁：加锁/解锁

优势：
- 自动管理，不会忘记释放
- 异常安全（即使发生异常，析构函数也会被调用）
- 代码更简洁

示例：
class FileHandler {
public:
    FileHandler(string filename) {
        // 构造函数：打开文件
    }
    ~FileHandler() {
        // 析构函数：关闭文件
    }
};
)" << endl;

    return 0;
}

// ============================================
// 第二部分：基础操作实践
// ============================================

#include <iostream>
#include <string>
using namespace std;

// --------------------------------------------
// 2.1 示例1：简单的析构函数
// --------------------------------------------

// 定义一个简单的类，演示析构函数的调用
class SimpleClass {
private:
    string name;

public:
    // 构造函数
    SimpleClass(string n) : name(n) {
        cout << "构造函数：创建对象 " << name << endl;
    }

    // 析构函数
    ~SimpleClass() {
        cout << "析构函数：销毁对象 " << name << endl;
    }
};

// --------------------------------------------
// 2.2 示例2：动态内存管理
// --------------------------------------------

// 定义一个动态数组类，演示资源管理
class DynamicArray {
private:
    int* data;      // 指向动态数组的指针
    int size;       // 数组大小

public:
    // 构造函数：分配内存
    DynamicArray(int s) : size(s) {
        data = new int[size];  // 动态分配内存
        cout << "构造函数：分配 " << size << " 个整数的内存" << endl;

        // 初始化数组为0
        for (int i = 0; i < size; i++) {
            data[i] = 0;
        }
    }

    // 析构函数：释放内存
    ~DynamicArray() {
        cout << "析构函数：释放内存" << endl;
        delete[] data;  // 释放动态分配的内存
        data = nullptr;  // 防止悬空指针
    }

    // 设置数组元素
    void set(int index, int value) {
        if (index >= 0 && index < size) {
            data[index] = value;
        }
    }

    // 获取数组元素
    int get(int index) {
        if (index >= 0 && index < size) {
            return data[index];
        }
        return -1;
    }

    // 显示数组
    void display() {
        cout << "数组内容：";
        for (int i = 0; i < size; i++) {
            cout << data[i] << " ";
        }
        cout << endl;
    }
};

// --------------------------------------------
// 2.3 示例3：对象生命周期演示
// --------------------------------------------

// 定义一个类，演示不同作用域的对象生命周期
class LifeCycleDemo {
private:
    string name;
    int id;

public:
    // 构造函数
    LifeCycleDemo(string n, int i) : name(n), id(i) {
        cout << "[" << id << "] 构造：" << name << endl;
    }

    // 析构函数
    ~LifeCycleDemo() {
        cout << "[" << id << "] 析构：" << name << endl;
    }

    void display() {
        cout << "[" << id << "] 使用：" << name << endl;
    }
};

// 全局对象
LifeCycleDemo globalObj("全局对象", 1);

// 测试函数
void testFunction() {
    cout << "\n进入testFunction函数" << endl;

    // 局部对象
    LifeCycleDemo localObj("局部对象", 2);
    localObj.display();

    cout << "离开testFunction函数" << endl;
    // 函数结束时，localObj自动销毁，调用析构函数
}

int main() {
    cout << string(60, '=') << endl;
    cout << "第二部分：基础操作实践" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 2.1 简单的析构函数
    // --------------------------------------------

    cout << "\n2.1 简单的析构函数" << endl;
    cout << string(60, '-') << endl;

    {
        // 创建对象：调用构造函数
        SimpleClass obj1("对象1");
        SimpleClass obj2("对象2");

        cout << "对象正在使用中..." << endl;

        // 离开作用域：自动调用析构函数
    }
    cout << "已离开作用域，对象已销毁" << endl;

    // --------------------------------------------
    // 2.2 动态内存管理
    // --------------------------------------------

    cout << "\n2.2 动态内存管理" << endl;
    cout << string(60, '-') << endl;

    {
        // 创建动态数组对象
        DynamicArray arr(5);

        // 设置数组元素
        arr.set(0, 10);
        arr.set(1, 20);
        arr.set(2, 30);
        arr.set(3, 40);
        arr.set(4, 50);

        // 显示数组
        arr.display();

        // 离开作用域：自动调用析构函数，释放内存
    }
    cout << "动态数组已销毁，内存已释放" << endl;

    // --------------------------------------------
    // 2.3 对象生命周期演示
    // --------------------------------------------

    cout << "\n2.3 对象生命周期演示" << endl;
    cout << string(60, '-') << endl;

    cout << "\n程序开始（全局对象已创建）" << endl;

    // 调用测试函数
    testFunction();

    cout << "\n程序即将结束（全局对象即将销毁）" << endl;

    return 0;
}

/*
==============================================
🔍 深入理解：析构函数的调用顺序（选学）
==============================================

如果你想知道"为什么"，可以阅读这部分。
如果觉得难，可以跳过，不影响后续学习。

【析构函数的调用顺序】

1. 局部对象
   - 按创建顺序的逆序销毁
   - 后创建的先销毁（栈的特性）

示例：
{
    Object obj1;  // 先创建
    Object obj2;  // 后创建
}
// 销毁顺序：obj2 → obj1

2. 成员对象
   - 先调用类的析构函数
   - 再按成员声明顺序的逆序销毁成员对象

示例：
class Container {
    Object obj1;
    Object obj2;
    ~Container() {
        // 先执行这里
    }
    // 然后销毁：obj2 → obj1
};

3. 继承关系
   - 先调用派生类的析构函数
   - 再调用基类的析构函数

示例：
class Base {
    ~Base() { }
};
class Derived : public Base {
    ~Derived() { }  // 先调用
};
// 然后调用Base的析构函数

4. 动态对象
   - delete时调用析构函数
   - 必须手动delete，否则不会调用析构函数

示例：
Object* ptr = new Object();
delete ptr;  // 调用析构函数

【内存泄漏】

什么是内存泄漏？
- 动态分配的内存没有被释放
- 程序无法再使用这块内存
- 内存泄漏累积会导致程序崩溃

常见原因：
1. 忘记delete
2. 异常导致delete未执行
3. 指针丢失（无法delete）

预防方法：
1. 使用RAII（在析构函数中释放资源）
2. 使用智能指针（后续会学习）
3. 避免裸指针

==============================================
*/

// ============================================
// 第三部分：动态对象管理
// ============================================

#include <iostream>
#include <string>
using namespace std;

// 定义一个类，演示动态对象的管理
class DynamicObject {
private:
    string name;
    int* data;

public:
    // 构造函数
    DynamicObject(string n, int value) : name(n) {
        data = new int(value);  // 动态分配内存
        cout << "构造：" << name << ", 分配内存，值=" << *data << endl;
    }

    // 析构函数
    ~DynamicObject() {
        cout << "析构：" << name << ", 释放内存" << endl;
        delete data;  // 释放内存
        data = nullptr;
    }

    void display() {
        cout << name << " 的值：" << *data << endl;
    }
};

int main() {
    cout << string(60, '=') << endl;
    cout << "第三部分：动态对象管理" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 3.1 栈对象（自动管理）
    // --------------------------------------------

    cout << "\n3.1 栈对象（自动管理）" << endl;
    cout << string(60, '-') << endl;

    {
        DynamicObject obj1("栈对象1", 100);
        obj1.display();

        // 离开作用域，自动调用析构函数
    }
    cout << "栈对象已自动销毁" << endl;

    // --------------------------------------------
    // 3.2 堆对象（手动管理）
    // --------------------------------------------

    cout << "\n3.2 堆对象（手动管理）" << endl;
    cout << string(60, '-') << endl;

    // 创建堆对象
    DynamicObject* ptr = new DynamicObject("堆对象1", 200);
    ptr->display();

    // 必须手动delete，否则内存泄漏
    delete ptr;  // 调用析构函数，释放内存
    cout << "堆对象已手动销毁" << endl;

    // --------------------------------------------
    // 3.3 内存泄漏示例（错误示范）
    // --------------------------------------------

    cout << "\n3.3 内存泄漏示例（错误示范）" << endl;
    cout << string(60, '-') << endl;

    cout << "创建堆对象但不delete..." << endl;
    DynamicObject* ptr2 = new DynamicObject("泄漏对象", 300);
    ptr2->display();

    // ❌ 错误：忘记delete，导致内存泄漏
    // delete ptr2;  // 应该调用这行

    cout << "注意：这个对象没有被delete，造成内存泄漏！" << endl;
    cout << "（在实际项目中必须避免）" << endl;

    return 0;
}

// ============================================
// 第四部分：常见错误和陷阱 ⭐⭐⭐⭐⭐
// ============================================

#include <iostream>
#include <string>
using namespace std;

int main() {
    cout << string(60, '=') << endl;
    cout << "常见错误和陷阱 ⭐⭐⭐⭐⭐" << endl;
    cout << string(60, '=') << endl;

    // --------------------------------------------
    // 4.1 错误1：忘记释放动态内存
    // --------------------------------------------

    cout << "\n4.1 错误1：忘记释放动态内存" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class MyClass {
private:
    int* data;
public:
    MyClass() {
        data = new int[100];  // 分配内存
    }
    // 没有析构函数，内存泄漏！
};

结果：内存泄漏，程序占用的内存越来越多

原因：动态分配的内存没有被释放

✅ 正确代码：
class MyClass {
private:
    int* data;
public:
    MyClass() {
        data = new int[100];
    }
    ~MyClass() {
        delete[] data;  // 释放内存
        data = nullptr;
    }
};

记忆技巧：
- 有new就要有delete
- 在析构函数中释放资源
- 使用RAII原则
)" << endl;

    // --------------------------------------------
    // 4.2 错误2：delete和delete[]混用
    // --------------------------------------------

    cout << "\n4.2 错误2：delete和delete[]混用" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
int* arr = new int[10];
delete arr;  // 错误：应该用delete[]

结果：未定义行为，可能崩溃或内存泄漏

原因：new[]和delete[]必须配对使用

✅ 正确代码：
int* arr = new int[10];
delete[] arr;  // 正确：使用delete[]

规则：
- new → delete
- new[] → delete[]
- 不能混用

记忆技巧：
- 数组用new[]，就用delete[]
- 单个对象用new，就用delete
)" << endl;

    // --------------------------------------------
    // 4.3 错误3：重复delete
    // --------------------------------------------

    cout << "\n4.3 错误3：重复delete" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
int* ptr = new int(10);
delete ptr;
delete ptr;  // 错误：重复delete

结果：程序崩溃

原因：同一块内存不能释放两次

✅ 正确代码：
int* ptr = new int(10);
delete ptr;
ptr = nullptr;  // 设为nullptr，防止重复delete

if (ptr != nullptr) {
    delete ptr;  // 安全：不会重复delete
}

记忆技巧：
- delete后立即设为nullptr
- delete前检查是否为nullptr
)" << endl;

    // --------------------------------------------
    // 4.4 错误4：析构函数中抛出异常
    // --------------------------------------------

    cout << "\n4.4 错误4：析构函数中抛出异常" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
~MyClass() {
    if (error) {
        throw exception();  // 错误：析构函数中抛出异常
    }
}

结果：程序可能崩溃

原因：析构函数中抛出异常会导致未定义行为

✅ 正确代码：
~MyClass() {
    try {
        // 清理资源
    } catch (...) {
        // 捕获所有异常，不让异常逃出析构函数
    }
}

记忆技巧：
- 析构函数不应该抛出异常
- 如果可能抛出异常，在析构函数内捕获
)" << endl;

    // --------------------------------------------
    // 4.5 错误5：忘记虚析构函数
    // --------------------------------------------

    cout << "\n4.5 错误5：忘记虚析构函数（继承时）" << endl;
    cout << string(60, '-') << endl;

    cout << R"(
❌ 错误代码：
class Base {
public:
    ~Base() { }  // 非虚析构函数
};

class Derived : public Base {
private:
    int* data;
public:
    ~Derived() { delete[] data; }
};

Base* ptr = new Derived();
delete ptr;  // 只调用Base的析构函数，Derived的析构函数不会被调用

结果：内存泄漏

原因：基类的析构函数不是虚函数

✅ 正确代码：
class Base {
public:
    virtual ~Base() { }  // 虚析构函数
};

记忆技巧：
- 如果类会被继承，析构函数应该是虚函数
- 后续学习继承时会详细讲解
)" << endl;

    return 0;
}

// ============================================
// 第五部分：函数卡片速查
// ============================================

#include <iostream>
using namespace std;

int main() {
    cout << "函数卡片速查" << endl;

    cout << R"(
【析构函数】

语法：~ClassName()
参数：无参数
返回：无返回类型

作用：
- 对象销毁时自动调用
- 用于释放资源（内存、文件等）

示例：
class MyClass {
public:
    ~MyClass() {
        // 清理资源
    }
};

────────────────────────────────────

【new/delete】

new：动态分配内存
语法：Type* ptr = new Type;
      Type* arr = new Type[size];

delete：释放内存
语法：delete ptr;
      delete[] arr;

配对规则：
- new → delete
- new[] → delete[]

────────────────────────────────────

【nullptr】

作用：空指针常量（C++11）
用法：ptr = nullptr;

优势：
- 类型安全（比NULL更安全）
- 避免重复delete
)" << endl;

    return 0;
}

// ============================================
// 练习题
// ============================================

#include <iostream>
using namespace std;

int main() {
    cout << "练习题" << endl;

    cout << R"(
1. 设计一个字符串类
   要求：
   - 使用动态内存存储字符串
   - 构造函数分配内存
   - 析构函数释放内存
   提示：使用char*和new/delete

2. 设计一个文件日志类
   要求：
   - 构造函数打开日志文件
   - 析构函数关闭日志文件
   - 提供写入日志的方法
   提示：使用ofstream

3. 观察对象生命周期
   要求：
   - 创建全局对象、局部对象、动态对象
   - 观察构造函数和析构函数的调用顺序
   - 理解不同对象的生命周期

4. 内存泄漏检测
   要求：
   - 故意制造内存泄漏
   - 使用工具检测内存泄漏
   - 修复内存泄漏
   提示：可以使用Valgrind等工具

5. RAII实践
   要求：
   - 设计一个资源管理类
   - 构造函数获取资源
   - 析构函数释放资源
   - 确保异常安全
)" << endl;

    return 0;
}
